# =============================================================================
# Pramaan (TimeTrack) — Environment variables
# Copy this file to .env in the project root (or backend/.env) and fill in values.
# =============================================================================

# --- Required in production ---
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# --- Database (optional: omit to use SQLite timetrack.db) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/timetrack
# POSTGRESQL_URI=postgresql://user:password@localhost:5432/timetrack

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=true

# --- Super admin (used by `flask seed-dev` to create the login account in the database) ---
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-me

# --- Optional: dev seed tenant (flask seed-dev) ---
# DEV_TENANT_COMPANY=Demo Company
# DEV_TENANT_EMAIL=admin@demo.local
# DEV_MANAGER_USERNAME=manager
# DEV_MANAGER_PASSWORD=manager123

# --- Stripe (tenant signup / subscriptions) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_STANDARD=price_...
STRIPE_PRICE_ID_PREMIUM=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
# For local Stripe CLI forwarding:
# STRIPE_WEBHOOK_SECRET_DEV=whsec_...
STRIPE_SUCCESS_URL=http://localhost:5000/signup-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5000/signup?cancelled=true
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5000/super-admin.html

# --- Email (optional; welcome emails disabled if unset) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# --- App URLs ---
APP_LOGIN_URL=http://localhost:5000/login.html
